<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <!-- ── HEADER ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="178dp"
            android:background="@drawable/bg_home_header"
            android:paddingStart="22dp"
            android:paddingTop="26dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivHeaderProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person_placeholder"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                app:strokeColor="@color/orange_light"
                app:strokeWidth="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/ivHeaderProfile"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHeaderGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola, Musico!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Que vamos a crear hoy?"
                    android:textSize="13sp"
                    android:textColor="@color/orange_light"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnNotifications"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_notifications"
                    android:background="@drawable/bg_action_create"
                    android:padding="10dp"
                    app:tint="@color/black_primary" />

                <ImageButton
                    android:id="@+id/btnMessages"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_chat"
                    android:background="@drawable/bg_action_create"
                    android:padding="10dp"
                    app:tint="@color/black_primary" />
            </LinearLayout>
        </RelativeLayout>

        <!-- ── BUSCADOR ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="-28dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/gray_hint" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Buscar musicos, proyectos o demos..."
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:imeOptions="actionSearch"
                    android:inputType="text" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── ACCIONES RÁPIDAS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="26dp"
            android:gravity="center">

            <!-- Crear Proyecto -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickActionCreate"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_add_project"
                    app:iconSize="24dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/orange_light"
                    app:iconTint="@color/orange_dark"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crear"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="7dp"
                    android:textColor="@color/black_soft"/>
            </LinearLayout>

            <!-- Buscar Musicos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickActionDiscover"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_group"
                    app:iconSize="24dp"
                    app:iconPadding="0dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#E3F2FD"
                    app:iconTint="#1976D2"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explorar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="7dp"
                    android:textColor="@color/black_soft"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── ESTADO DEL USUARIO ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/outline_soft"
                app:strokeWidth="1dp"
                android:layout_marginEnd="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proyectos"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/orange_dark"/>
                    <TextView
                        android:id="@+id/tvActiveProjectsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 Activos"
                        android:layout_marginTop="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/outline_soft"
                app:strokeWidth="1dp"
                android:layout_marginStart="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tareas hoy"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/orange_dark"/>
                    <TextView
                        android:id="@+id/tvPendingTasksCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 Pendientes"
                        android:layout_marginTop="4dp"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── RECOMENDACIONES (SPOTIFY STYLE) ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:text="Basado en tus artistas"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_primary"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- ── DESCUBRIR MÚSICOS (CARRUSEL) ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:text="Descubrir talentos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_primary"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDiscoverMusicians"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- ── FEED DE PROYECTOS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proyectos destacados"
                    android:textColor="@color/black_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProjectFeedMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Ideas recientes con demos para escuchar"
                    android:textColor="@color/black_soft"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateProjectFromFeed"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/orange_light"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_add_project"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="22dp"
                app:iconTint="@color/orange_dark" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupProjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="24dp"
            app:checkedChip="@id/chipAllProjects"
            app:selectionRequired="true"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAllProjects"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Todos"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipProjectsWithDemo"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Con demo"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMyProjects"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mios"
                android:textColor="@color/chip_text_selector"
                app:checkedIconVisible="false"
                app:chipBackgroundColor="@color/chip_selector"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProjectFeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="24dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/containerEmptyProjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/orange_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_add_project"
                    app:tint="@color/orange_dark" />

                <TextView
                    android:id="@+id/tvEmptyProjects"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Todavia no hay proyectos publicados"
                    android:textAlignment="center"
                    android:textColor="@color/black_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmptyProjectsHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cuando alguien publique una idea con demo, va a aparecer aca."
                    android:textAlignment="center"
                    android:textColor="@color/black_soft"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateProjectEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    android:minWidth="0dp"
                    android:paddingHorizontal="18dp"
                    android:text="Crear proyecto"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:backgroundTint="@color/black_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_add_project"
                    app:iconPadding="8dp"
                    app:iconSize="18dp"
                    app:iconTint="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── ACTIVIDAD RECIENTE ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:text="Actividad reciente"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/black_primary"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:strokeColor="@color/outline_soft"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/containerRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">
                <!-- Se llenará dinámicamente o con placeholders -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Te uniste al proyecto 'Rock In Rio'"
                    android:textSize="13sp"
                    android:textColor="@color/black_soft"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Subiste una nueva demo: 'Blues Jam'"
                    android:textSize="13sp"
                    android:textColor="@color/black_soft"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
