<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Header con botón volver -->
    <RelativeLayout
        android:id="@+id/publishHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/black_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="PUBLICA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black_primary"
            android:letterSpacing="0.1"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/publishHeader"
        android:layout_above="@id/btnPublicar"
        android:fillViewport="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF8E1"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Título -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Titulo del proyecto:"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etProjectTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="..........................................................................."
                    android:textColorHint="@color/black_soft"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"
                    android:inputType="text"/>

                <!-- Descripción -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripcion breve del proyecto:"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FAFAFA"
                    app:strokeColor="#EEEEEE"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="24dp">

                    <EditText
                        android:id="@+id/etProjectDescription"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:padding="16dp"
                        android:hint="Escribí algo"
                        android:gravity="top"
                        android:textSize="13sp"
                        android:textColor="@color/black_primary"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Género -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genero:"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etProjectGenre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="..........................................................................."
                    android:textColorHint="@color/black_soft"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"
                    android:inputType="text"/>

                <!-- Roles -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Que roles buscas:"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="16dp"/>

                <!-- Ubicación -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ubicacion/modalidad: Presencial - Remoto"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="24dp"/>

                <!-- Subir Demo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subi una demo:"
                    android:textSize="14sp"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUploadDemo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FAFAFA"
                    app:strokeColor="#EEEEEE"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_audio_file"
                            app:tint="@color/black_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arrastra un archivo: wav,mp3"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/black_soft"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_link"
                                app:tint="@color/black_soft"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Link"
                                android:textSize="12sp"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/black_soft"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Subir Imagen -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subi una imagen."
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:textColor="@color/black_primary"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUploadImage"
                    android:layout_width="140dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FAFAFA"
                    app:strokeColor="#EEEEEE"
                    app:strokeWidth="1dp"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivProjectPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="24dp"
                        android:src="@drawable/ic_image_placeholder"
                        app:tint="@color/black_soft"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>

    <!-- Botón Publicar Fijo -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPublicar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:text="Publicar"
        android:textSize="16sp"
        android:textColor="@color/white"
        app:backgroundTint="@color/black_primary"
        app:cornerRadius="14dp"/>

</RelativeLayout>