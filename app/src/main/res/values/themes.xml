<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AcordeHub" parent="Theme.Material3.Light.NoActionBar">

        <!-- Color principal → naranja -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorOnPrimary">@color/black_primary</item>

        <!-- Variante del primary → amarillo -->
        <item name="colorPrimaryContainer">@color/yellow_accent</item>
        <item name="colorOnPrimaryContainer">@color/black_primary</item>

        <!-- Secondary → negro -->
        <item name="colorSecondary">@color/black_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/black_soft</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Fondo de la app → blanco limpio -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black_primary</item>
        <item name="colorOnSurfaceVariant">@color/black_soft</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Outline (bordes de TextInputLayout) -->
        <item name="colorOutline">@color/black_soft</item>

        <!-- Botones: fondo negro, texto blanco -->
        <item name="materialButtonStyle">@style/Widget.AcordeHub.Button</item>

        <!-- TextInputLayout: borde negro -->
        <item name="textInputStyle">@style/Widget.AcordeHub.TextInputLayout</item>

    </style>

    <!-- ── Botón principal ── -->
    <style name="Widget.AcordeHub.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/black_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- ── Botón outlined (Google Sign-In) ── -->
    <style name="Widget.AcordeHub.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/black_primary</item>
        <item name="android:textColor">@color/black_primary</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- ── TextInputLayout con borde negro ── -->
    <style name="Widget.AcordeHub.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/black_primary</item>
        <item name="hintTextColor">@color/gray_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ── Chips (roles, géneros, nivel) ── -->
    <style name="Widget.AcordeHub.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/black_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="chipStrokeColor">@color/black_primary</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

</resources>