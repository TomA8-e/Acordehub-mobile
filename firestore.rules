rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isChatParticipant() {
      return signedIn()
        && resource.data.participantIds is list
        && request.auth.uid in resource.data.participantIds;
    }

    function willBeChatParticipant() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn();
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if willBeChatParticipant()
        && request.resource.data.participantIds.size() == 2;
      allow update: if isChatParticipant() && willBeChatParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId));
        }

        function isParentChatParticipant() {
          return signedIn()
            && request.auth.uid in parentChat().data.participantIds;
        }

        allow read: if isParentChatParticipant();
        allow create: if isParentChatParticipant()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }
  }
}
