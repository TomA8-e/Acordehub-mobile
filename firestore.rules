rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isChatParticipant() {
      return signedIn()
        && resource.data.participantIds is list
        && request.auth.uid in resource.data.participantIds;
    }

    function willBeChatParticipant() {
      return signedIn()
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn();
      allow update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /producerProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if willBeChatParticipant()
        && request.resource.data.participantIds.size() == 2;
      allow update: if isChatParticipant() && willBeChatParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId));
        }

        function isParentChatParticipant() {
          return signedIn()
            && request.auth.uid in parentChat().data.participantIds;
        }

        allow read: if isParentChatParticipant();
        allow create: if isParentChatParticipant()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }

    match /projects/{projectId} {
      function parentProject() {
        return get(/databases/$(database)/documents/projects/$(projectId));
      }

      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000
        && request.resource.data.genre is string
        && request.resource.data.genre.size() > 0
        && request.resource.data.genre.size() <= 80
        && request.resource.data.status == "active";
      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /joinRequests/{requesterUid} {
        allow read: if signedIn()
          && (request.auth.uid == requesterUid
            || resource.data.ownerUid == request.auth.uid
            || parentProject().data.ownerUid == request.auth.uid);
        allow create: if signedIn()
          && request.auth.uid == requesterUid
          && parentProject().data.ownerUid != request.auth.uid
          && request.resource.data.projectId == projectId
          && request.resource.data.ownerUid == parentProject().data.ownerUid
          && request.resource.data.requesterUid == request.auth.uid
          && request.resource.data.status == "pending";
        allow update: if signedIn()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "respondedAt"])
          && request.resource.data.status in ["accepted", "rejected"];
        allow delete: if false;
      }
    }

    match /userLikes/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if false;

      match /likedUsers/{targetUid} {
        allow read: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == targetUid);
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.targetUid == targetUid;
        allow delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /matches/{matchId} {
      function isMatchParticipant() {
        return signedIn()
          && resource.data.participantIds is list
          && request.auth.uid in resource.data.participantIds;
      }

      function willBeMatchParticipant() {
        return signedIn()
          && request.resource.data.participantIds is list
          && request.auth.uid in request.resource.data.participantIds;
      }

      allow read: if isMatchParticipant();
      allow create: if willBeMatchParticipant()
        && request.resource.data.participantIds.size() == 2;
      allow update: if isMatchParticipant() && willBeMatchParticipant();
      allow delete: if false;
    }

    match /connectionRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.requesterUid == request.auth.uid
          || resource.data.targetUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.requesterUid == request.auth.uid
        && request.resource.data.targetUid is string
        && request.resource.data.targetUid != request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if signedIn()
        && resource.data.targetUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
        && request.resource.data.status in ["accepted", "rejected"];
      allow delete: if false;
    }
  }
}
