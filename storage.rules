rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function validProjectAsset() {
      return request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|audio/mpeg|audio/mp3|audio/wav|audio/x-wav|audio/wave');
    }

    match /project_uploads/{userId}/{projectId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && validProjectAsset();
    }
  }
}
